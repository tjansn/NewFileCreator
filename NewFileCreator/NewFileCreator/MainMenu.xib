                        <rect key="frame" x="20" y="80" width="360" height="50"/>
                        <textFieldCell key="cell" lineBreakMode="wordWrapping" title="This app adds a 'New File' option to Finder's right-click context menu. Enable the extension in System Settings → Privacy &amp; Security → Extensions → Finder Extensions." id="txt-cell-002">
                            <font key="font" metaFont="system"/>
